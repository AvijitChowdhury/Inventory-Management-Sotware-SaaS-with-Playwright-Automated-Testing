flowchart LR
    subgraph Dev["Developer / CI"]
        RUN["python tests/e2e_pom.py"]
    end

    subgraph POM["Page Object Model (tests/pages/)"]
        BP["BasePage<br/>goto · screenshot · has_text"]
        LP["LandingPage"]
        AP["AuthPage<br/>sign_in · wait_until_signed_in"]
        OP["OnboardingPage<br/>create_org"]
        MP["ModulePage<br/>generic route wrapper"]
    end

    subgraph Runner["e2e_pom.py orchestrator"]
        FX["Playwright Chromium<br/>headless · 1280x1800"]
        S1["Landing + Auth render"]
        S2["Admin sign-in flow"]
        S3["Onboarding (conditional)"]
        S4["10 module routes"]
        S5["Sign-out + public home"]
    end

    subgraph App["StockFlow app under test"]
        LOCAL["Vite dev server<br/>localhost:8080"]
        SB["Supabase<br/>Auth + Postgres + RLS"]
    end

    subgraph Report["Reporting artifacts"]
        JSON["tests/results/report.json<br/>step status + timings"]
        SHOTS["docs/screenshots/*.png<br/>refreshed each run"]
        ALLURE["allure-report/<br/>Allure HTML dashboard"]
        RM["README.md<br/>embeds screenshots"]
    end

    RUN --> FX
    FX --> S1 --> S2 --> S3 --> S4 --> S5

    S1 --> LP
    S2 --> AP
    S3 --> OP
    S4 --> MP
    LP & AP & OP & MP --> BP

    S1 & S2 & S3 & S4 & S5 -->|HTTP| LOCAL
    LOCAL <-->|SDK / RPC| SB

    S1 & S2 & S3 & S4 & S5 -->|screenshot| SHOTS
    S1 & S2 & S3 & S4 & S5 -->|step result| JSON
    JSON --> ALLURE
    SHOTS --> RM

